<%- include('partials/header') %>

    <div class="row justify-content-center mt-4">
        <div class="col-md-8 col-lg-6">
            <div class="premium-form">
                <h3 class="fw-bold text-center mb-1">Edit Listing</h3>
                <p class="text-center text-muted mb-4 pb-2 border-bottom">Update the details for <%= product.title %>
                </p>
                <form action="/products/<%= product._id %>?_method=PUT" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="title" class="form-label fw-semibold text-dark">Product Title</label>
                        <input type="text" class="form-control" id="title" name="title" value="<%= product.title %>"
                            required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="price" class="form-label fw-semibold text-dark">Price ($)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">$</span>
                                <input type="number" step="0.01" min="0" class="form-control border-start-0 ps-0"
                                    id="price" name="price" value="<%= product.price %>" required>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label for="category" class="form-label fw-semibold text-dark">Category</label>
                            <select class="form-select" id="category" name="category" required>
                                <option value="Cars" <%=product.category==='Cars' ? 'selected' : '' %>>Cars</option>
                                <option value="Bikes" <%=product.category==='Bikes' ? 'selected' : '' %>>Bikes</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="make" class="form-label fw-semibold text-dark">Make</label>
                            <input type="text" class="form-control" id="make" name="make" value="<%= product.make %>"
                                required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="model" class="form-label fw-semibold text-dark">Model</label>
                            <input type="text" class="form-control" id="model" name="model" value="<%= product.model %>"
                                required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="year" class="form-label fw-semibold text-dark">Year</label>
                            <input type="number" class="form-control" id="year" name="year" value="<%= product.year %>"
                                required min="1886">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="mileage" class="form-label fw-semibold text-dark">Mileage (km)</label>
                            <input type="number" class="form-control" id="mileage" name="mileage"
                                value="<%= product.mileage %>" required min="0">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="condition" class="form-label fw-semibold text-dark">Condition</label>
                            <select class="form-select" id="condition" name="condition" required>
                                <option value="Excellent" <%=product.condition==='Excellent' ? 'selected' : '' %>
                                    >Excellent</option>
                                <option value="Good" <%=product.condition==='Good' ? 'selected' : '' %>>Good</option>
                                <option value="Fair" <%=product.condition==='Fair' ? 'selected' : '' %>>Fair</option>
                                <option value="Needs Work" <%=product.condition==='Needs Work' ? 'selected' : '' %>
                                    >Needs Work</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="image" class="form-label fw-semibold text-dark">Upload New Image (Optional)</label>
                        <input class="form-control" type="file" id="image" name="image" accept="image/*">
                        <% if (product.image) { %>
                            <div class="mt-2 text-muted small">Current image: <%= product.image.split('/').pop() %>
                            </div>
                            <% } %>
                    </div>
                    <div class="mb-4">
                        <label for="description" class="form-label fw-semibold text-dark">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="5"
                            required><%= product.description %></textarea>
                    </div>
                    <div class="d-grid gap-2 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">Save Changes</button>
                        <a href="/products/<%= product._id %>" class="btn btn-light fw-medium mt-1">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>