<%- include('partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
        <h2 class="fw-bold">Recently Added</h2>
    </div>

    <div class="row g-4">
        <% if (products.length===0) { %>
            <div class="col-12 text-center text-muted mt-5 py-5 bg-white rounded shadow-sm">
                <h4 class="fw-bold text-dark">No products found</h4>
                <p>Be the first to list an item on UsedMarket!</p>
                <a href="/products/new" class="btn btn-primary mt-3 px-4 py-2">Start Selling</a>
            </div>
            <% } else { %>
                <% for(let product of products) { %>
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card h-100 position-relative">
                            <% if (product.image) { %>
                                <img src="<%= product.image %>" class="card-img-top object-fit-cover"
                                    style="height: 200px;" alt="<%= product.title %>">
                                <% } else { %>
                                    <img src="https://via.placeholder.com/400x250?text=<%= product.title.split(' ').join('+') %>"
                                        class="card-img-top object-fit-cover" style="height: 200px;"
                                        alt="<%= product.title %>">
                                    <% } %>
                                        <div class="card-body d-flex flex-column">
                                            <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                                <h5 class="card-title fw-bold mb-0 text-truncate"
                                                    title="<%= product.title %>">
                                                    <%= product.title %>
                                                </h5>
                                            </div>
                                            <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
                                                <span class="badge bg-light text-dark border badge-category">
                                                    <%= product.category %>
                                                </span>
                                                <span class="text-muted small fw-medium"><i
                                                        class="bi bi-calendar-event me-1"></i>
                                                    <%= product.year ? product.year : 'N/A' %>
                                                </span>
                                                <span class="text-muted small fw-medium"><i
                                                        class="bi bi-speedometer2 me-1"></i>
                                                    <%= product.mileage !==undefined && product.mileage !==null ?
                                                        product.mileage.toLocaleString() : 'N/A' %> km
                                                </span>
                                            </div>
                                            <h4 class="text-primary fw-bold mb-3">$<%= product.price.toLocaleString() %>
                                            </h4>
                                            <p class="card-text text-secondary flex-grow-1 small">
                                                <%= product.description.length> 80 ? product.description.substring(0,
                                                    80) + '...' : product.description %>
                                            </p>
                                            <a href="/products/<%= product._id %>"
                                                class="btn btn-outline-primary w-100 stretched-link mt-auto fw-medium">View
                                                Details</a>
                                        </div>
                        </div>
                    </div>
                    <% } %>
                        <% } %>
    </div>

    <%- include('partials/footer') %>