<%- include('partials/header') %>

    <nav aria-label="breadcrumb" class="mb-4 mt-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/products" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item"><a href="/products?category=<%= product.category %>"
                    class="text-decoration-none">
                    <%= product.category %>
                </a></li>
            <li class="breadcrumb-item active" aria-current="page">
                <%= product.title %>
            </li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0 premium-form p-0 overflow-hidden mb-5">
        <div class="row g-0">
            <div class="col-md-6 bg-light d-flex align-items-center justify-content-center">
                <% if (product.image) { %>
                    <img src="<%= product.image %>" class="img-fluid w-100 h-100 object-fit-cover"
                        alt="<%= product.title %>" style="min-height: 400px; max-height: 600px;">
                    <% } else { %>
                        <img src="https://via.placeholder.com/800x600?text=<%= product.title.split(' ').join('+') %>"
                            class="img-fluid w-100 h-100 object-fit-cover" alt="<%= product.title %>"
                            style="min-height: 400px; max-height: 600px;">
                        <% } %>
            </div>
            <div class="col-md-6">
                <div class="p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h1 class="fw-bold mb-0 text-dark display-6">
                            <%= product.title %>
                        </h1>
                    </div>

                    <div class="mb-4">
                        <span class="badge bg-secondary badge-category fs-6 fw-normal">
                            <%= product.category %>
                        </span>
                    </div>

                    <h2 class="text-primary fw-bold mb-4 display-5">$<%= product.price.toLocaleString() %>
                    </h2>

                    <div class="row mb-4">
                        <div class="col-6 mb-3">
                            <div class="text-muted small fw-semibold text-uppercase tracking-wide">Make & Model</div>
                            <div class="fw-bold fs-5 text-dark">
                                <%= product.make || 'N/A' %>
                                    <%= product.model || '' %>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="text-muted small fw-semibold text-uppercase tracking-wide">Year</div>
                            <div class="fw-bold fs-5 text-dark">
                                <%= product.year || 'N/A' %>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="text-muted small fw-semibold text-uppercase tracking-wide">Mileage</div>
                            <div class="fw-bold fs-5 text-dark">
                                <%= product.mileage !==undefined && product.mileage !==null ?
                                    product.mileage.toLocaleString() + ' km' : 'N/A' %>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="text-muted small fw-semibold text-uppercase tracking-wide">Condition</div>
                            <div class="fw-bold fs-5 text-dark">
                                <%= product.condition || 'N/A' %>
                            </div>
                        </div>
                    </div>

                    <div class="mb-5">
                        <h5 class="fw-semibold text-dark mb-3">Description</h5>
                        <p class="text-secondary lh-lg fs-6">
                            <%= product.description %>
                        </p>
                    </div>

                    <div class="d-flex align-items-center text-muted small mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                            class="bi bi-clock me-2" viewBox="0 0 16 16">
                            <path
                                d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
                            <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
                        </svg>
                        Listed on <%= product.createdAt.toLocaleDateString('en-US', { year: 'numeric' , month: 'long' ,
                            day: 'numeric' }) %>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex flex-wrap gap-3">
                        <a href="/products/<%= product._id %>/edit"
                            class="btn btn-outline-secondary px-4 fw-medium flex-grow-1 flex-md-grow-0">Edit Listing</a>
                        <form action="/products/<%= product._id %>?_method=DELETE" method="POST"
                            class="d-inline flex-grow-1 flex-md-grow-0">
                            <button type="submit" class="btn btn-danger px-4 fw-medium w-100"
                                onclick="return confirm('Are you sure you want to delete this listing? This action cannot be undone.');">Delete
                                Listing</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>